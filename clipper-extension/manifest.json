{
  "manifest_version": 3,
  "name": "Markio Web Clipper",
  "version": "1.0.0",
  "description": "Clip the current page or selection and send it to your locally running Markio WebClipper endpoint.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Markio Web Clipper"
  }
}
