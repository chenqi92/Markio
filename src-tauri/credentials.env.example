# 内置网盘 OAuth 凭据（编译期注入，不提交真实值）
#
# 用法：复制本文件为 src-tauri/credentials.env（已被 .gitignore 忽略），
# 填入你在各开放平台注册得到的 key/secret，再 `pnpm tauri:build`。
# 留空或缺失的 provider 会回退到「用户自填 client_id」。
# CI 里也可改用同名环境变量注入（见 build.rs）。
#
# 各家申请入口：
#   Google   : https://console.cloud.google.com/apis/credentials  （OAuth 客户端类型选 Desktop app）
#   OneDrive : https://portal.azure.com  → Microsoft Entra ID → 应用注册（平台选「移动和桌面应用程序」，加 http://localhost，允许公共客户端流）
#   Dropbox  : https://www.dropbox.com/developers/apps  （Scoped access，启用 PKCE）
#   百度网盘  : https://pan.baidu.com/union  （拿 AppKey/SecretKey）
#   阿里云盘  : https://www.alipan.com/developer  （拿 appId/appSecret）

# Google / 微软 / Dropbox 走 PKCE 公共客户端，不需要 secret
MARKIO_GDRIVE_CLIENT_ID=
MARKIO_ONEDRIVE_CLIENT_ID=
MARKIO_DROPBOX_CLIENT_ID=
MARKIO_DROPBOX_SECRET=

# 百度 / 阿里强制要 secret（直接内置进客户端，可被逆向提取，已知权衡）
MARKIO_BAIDU_CLIENT_ID=
MARKIO_BAIDU_SECRET=
MARKIO_ALIYUN_APP_ID=
MARKIO_ALIYUN_SECRET=
