{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "markio",
  "version": "0.1.0",
  "identifier": "com.welape.mdview",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:18642",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "markio",
        "width": 1280,
        "height": 800,
        "minWidth": 920,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "devtools": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' data: blob: https:; media-src 'self' data: blob:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'wasm-unsafe-eval' blob:; worker-src 'self' blob:; connect-src 'self' ipc: http://ipc.localhost https: data: blob:; frame-src 'none'; object-src 'none'; base-uri 'self'",
      "assetProtocol": {
        "enable": false,
        "scope": []
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERCOTczMEI2NkQ4RUQzNkEKUldScTA0NXR0akNYMjlSYm9FWkNETTR0WE4waU5GM0lucTVSbXVNNnFLdVJ5STI2ejdwL2FjalAK",
      "endpoints": [
        "https://github.com/chenqi92/Markio/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "本地优先的 Markdown 阅读器",
    "longDescription": "markio 是一款本地优先的 Markdown 阅读器，支持 8 套主题、源码/分屏/阅读三种视图、命令面板与全文搜索。",
    "copyright": "© 2026 welape",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "entitlements/macos.entitlements",
      "exceptionDomain": null,
      "frameworks": [],
      "providerShortName": null
    },
    "windows": {
      "wix": {
        "language": [
          "zh-CN",
          "en-US"
        ]
      }
    }
  }
}
